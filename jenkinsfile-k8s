pipeline {
  agent {
    label 'k8s-agent'
  }

  stages {

    stage('Checkout Code') {
      steps {
        git branch: 'main',
            url: 'https://github.com/darninidhi2122/kubecoin-project.git'
      }
    }

    stage('Deploy Kubecoin App') {
      steps {
        container('kubectl') {
          sh '''
          kubectl apply -f k8s/level-3-configmaps-secrets/ -n jenkins
          '''
        }
      }
    }

    stage('Verify Deployment') {
      steps {
        container('kubectl') {
          sh '''
          kubectl get pods -n jenkins
          kubectl get svc -n jenkins
          '''
        }
      }
    }

  }
}
