pipeline {
  agent {
    label 'k8s-agent'
  }

  stages {

    stage('Checkout Code') {
      steps {
        git 'https://github.com/darninidhi2122/kubecoin-project.git'
      }
    }

    stage('Check Files') {
      steps {
        container('kubectl') {
          sh '''
          echo "Listing repository files"
          ls -R
          '''
        }
      }
    }

    stage('Deploy Kubernetes Resources') {
      steps {
        container('kubectl') {
          sh '''
          kubectl apply -f "assignment/k8s/deployment.yaml"
          kubectl apply -f  "assignemnt/k8s/service.yaml"
          '''
        }
      }
    }

    stage('Verify Deployment') {
      steps {
        container('kubectl') {
          sh '''
          kubectl get pods -n jenkins
          kubectl get svc -n jenkins
          '''
        }
      }
    }

  }
}
